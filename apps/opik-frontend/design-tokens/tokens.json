      }
    },
    "small-accented": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 500,
        "fontSize": "14px",
        "lineHeight": "20px"
      }
    },
    "xsmall": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontWeight": 400,
        "fontSize": "12px",
